    {
      "parameters": {
        "jsCode": "// 1. Grab the text using your exact JSON path!\nlet rawText = $input.first().json.candidates[0].content.parts[0].text || \"\";\n\n// 2. DEBUGGING CHECK: Just in case the audio was truly silent\nif (rawText === \"\") {\n  return { json: { text: \"ERROR: The audio transcript was completely empty.\" } };\n}\n\n// 3. Define the filler words to hunt down (um, uh, ah, etc.)\nconst fillerRegex = /\\b(u+m+|u+h+|a+h+|like|you know|basically|well)\\b/gi;\nlet cleanText = rawText.replace(fillerRegex, \"\");\n\n// 4. Clean up any weird pauses or double spaces\ncleanText = cleanText.replace(/\\.{2,}/g, \" \"); // Removes \"...\"\ncleanText = cleanText.replace(/\\s{2,}/g, \" \"); // Turns double spaces into single spaces\ncleanText = cleanText.trim(); \n\n// 5. FAILSAFE: If the user literally ONLY said \"ummm\", and we deleted it, \n// return the original text so the bot doesn't crash on an empty string.\nif (cleanText === \"\") {\n  cleanText = rawText;\n}\n\n// 6. Output the perfectly clean text to the Merge node!\nreturn {\n  json: {\n    text: cleanText\n  }\n};"
      },
